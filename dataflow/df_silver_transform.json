{
	"name": "df_silver_transform",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_silver_salesorderheader",
						"type": "DatasetReference"
					},
					"name": "sourceSales"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_gold_salesorders",
						"type": "DatasetReference"
					},
					"name": "sinkGold"
				}
			],
			"transformations": [
				{
					"name": "RenameColumns"
				},
				{
					"name": "filterNulls"
				},
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> sourceSales",
				"sourceSales select(skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> RenameColumns",
				"RenameColumns filter(true()) ~> filterNulls",
				"filterNulls derive(ingestion_date =  currentDate(),",
				"          source_system = 'ADF') ~> derivedColumn1",
				"derivedColumn1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sinkGold"
			]
		}
	}
}